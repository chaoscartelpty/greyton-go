# === Email Configuration ===
# For Zoho Mail (recommended): Use a 16-character App-Specific Password
# Generate at: mail.zoho.com → Settings → Security → App Passwords
EMAIL_USER=your-email@zohomail.com
EMAIL_PASS=your-16-char-app-password
ADMIN_EMAIL=admin@example.com

# === Image Hosting ===
# Get a free API key at https://imghosting.in
IMG_HOSTING_API_KEY=your-api-key

# === Backend API Base URL ===
# For local dev: leave empty (uses same origin)
VITE_API_BASE_URL=

# === Server ===
PORT=3000
NODE_ENV=development